# ==============================================================================
# SSPA Research Lab — variables de entorno
# Copiar como .env y ajustar antes del primer deploy
# ==============================================================================

# Clave secreta para firmar los tokens JWT (generar con: openssl rand -hex 32)
SECRET_KEY=change-me-in-production

# Duración del token en horas (default: 72)
TOKEN_EXPIRE_HOURS=72

# PostgreSQL — usar las mismas credenciales que sspa_postgres del stack de infra
# La DB research_lab_db se crea automáticamente si no existe
DATABASE_URL=postgresql://USUARIO:PASSWORD@postgres:5432/research_lab_db

# URL pública de la app (usada en los links de los emails de invitación)
APP_URL=https://lab.aural-syncro.com.ar

# Gmail SMTP_SSL — misma App Password que management_platform
# Sin estas variables los emails solo se loguean en stdout (modo dev)
GMAIL_USER=juanpablo.chancay@aural-syncro.com.ar
GMAIL_APP_PASSWORD=<app-password-16-chars>
