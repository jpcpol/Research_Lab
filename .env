# Clave secreta para firmar los tokens JWT (generar con: openssl rand -hex 32)
SECRET_KEY=6143ced62d76454514813abb220ca2531b5fb5fc9fba57c2a2049bb32d9d3424

# Duración del token en horas (default: 72)
TOKEN_EXPIRE_HOURS=72

# Registro público: true = cualquiera puede crear cuenta, false = solo por invitación (default)
REGISTRATION_OPEN=false

# ── GitHub App (credenciales por proyecto, configuradas en creación/edición del proyecto) ──
