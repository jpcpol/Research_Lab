{
  "compilerOptions": {
    "baseUrl":        ".",
    "paths": {
      "obsidian": ["./node_modules/obsidian/obsidian.d.ts"]
    },
    "inlineSourceMap": true,
    "inlineSources":  true,
    "module":         "ESNext",
    "target":         "ES2018",
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler",
    "importHelpers":  true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib":            ["ES2018", "DOM"]
  },
  "include": ["*.ts"]
}
